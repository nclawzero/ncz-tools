# zterm environment configuration template.
#
# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit it.
#
# zterm reads these at startup via dotenvy. Everything here is
# optional; zterm works with safe defaults if no .env is present.

# ---- zeroclaw daemon (CLI flags override these) ----
# Gateway URL for your zeroclaw daemon. Default is localhost:42617.
# ZEROCLAW_URL=http://localhost:42617
# ZEROCLAW_TOKEN=your-zeroclaw-pairing-token

# ---- MNEMOS memory system (optional) ----
# MNEMOS is a separate memory-storage daemon (v3.0 REST contract,
# unified API on port 5002, Bearer token auth). If both URL and
# TOKEN are set, zterm's /memory command talks to it. If either
# is empty or unset, memory commands disable themselves cleanly.
# MNEMOS_URL=http://localhost:5002
# MNEMOS_TOKEN=your-mnemos-bearer-token
